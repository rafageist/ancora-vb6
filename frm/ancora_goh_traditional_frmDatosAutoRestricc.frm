Attribute VB_Name = "frmDatosAutoRestricc"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Attribute VB_Ext_KEY = "RVB_UniqueId" ,"489BC2D102C8"
Option Explicit

'Form Restricciones en tiempo de los objetos

'<!- ATRIBUTOS -!>
    Dim refre As Boolean
    Dim resultbutton As Integer
    Dim modo As Integer
    Dim FichaIndex As Integer

'<!- EVENTOS !->

    Private Sub cmdAplicar_Click()
        Dim listaids() As Long
        Dim cantids As Long, r As Variant
        Dim i As Long
        r = interface.MessageDlg("Antes de proceder...", "Esta acción no podrá revertirse a menos que cierre " & Chr(10) & Chr(13) & " la aplicación sin guardar los cambios.żEstá seguro que desea continuar?", vbQuestion, "No", "Sí")
        If r = 2 Then
                cantids = 0
                For i = 1 To lvw.ListItems.Count
                    If lvw.ListItems(i).Checked Then
                        cantids = cantids + 1
                        ReDim Preserve listaids(cantids)
                        listaids(cantids) = i
                    End If
                Next
                Dim per As String
                If cboPer.ListIndex <= 1 Then per = "" Else per = ancora.periodos(cboPer.ListIndex).id
                Dim arreglo As Long
                Select Case FichaIndex
                    Case 1: arreglo = dESPECIALIDAD
                    Case 2: arreglo = dBRIGADA
                    Case 3: arreglo = dASIG
                    Case 4: arreglo = dPROFE
                    Case 5: arreglo = dLUGAR
                    Case 6: arreglo = dPERIODO
                    Case 7: arreglo = dRECURSO
                End Select
                ancora.AutoRestriccDeBotonesRestriccion arreglo, listaids, cantids, per, chkEliminarActuales.value = 1
            End If
    
    End Sub
    Private Sub cmdInvertir_Click()
        interface.SelectAll_Lvw lvw, 2, IIf(chkUsarSeleccionados.value, True, False)
    End Sub
    
    Private Sub cmdNinguna_Click()
        interface.SelectAll_Lvw lvw, 0, IIf(chkUsarSeleccionados.value, True, False)
    End Sub
    
    Private Sub cmdOK_Click()
        Hide
    End Sub
    
    Private Sub cmdTodas_Click()
        interface.SelectAll_Lvw lvw, 1, IIf(chkUsarSeleccionados.value, True, False)
    End Sub
    Private Sub cmdEntireDia_Click(index As Integer)
        Dim i As Long
    
        For i = 1 To MAX_TURNOS
            If cmdRes((i - 1) * MAX_DIAS + (index)).Enabled Then cmdRes_Click (i - 1) * MAX_DIAS + (index)
        Next
    
    End Sub
    
    Private Sub cmdEntireTurno_Click(index As Integer)
        Dim i As Long
    
        For i = 1 To MAX_DIAS
            If cmdRes((index) * MAX_DIAS + (i - 1)).Enabled Then cmdRes_Click (index) * MAX_DIAS + (i - 1)
        Next
    
    End Sub
    
    Private Sub cmdRes_Click(index As Integer)
        Dim dia As Long, turno As Long
        index = index + 1
        turno = Int(((index - 1) / MAX_DIAS) + 1)
        dia = Int(index - (turno - 1) * MAX_DIAS)
        If BotonesRestriccion(dia, turno) Then
            cmdRes(index - 1).Picture = cmdEmpty.Picture
            BotonesRestriccion(dia, turno) = False
        Else
            If modo <> 6 Then
                cmdRes(index - 1).Picture = cmdRestricc.Picture
            Else
                cmdRes(index - 1).Picture = cmdZpriori.Picture
            End If
    
            BotonesRestriccion(dia, turno) = True
        End If
    
    End Sub

    Private Sub Form_Load()
        interface.SkinFor Me
    End Sub
    
    Private Sub Form_Terminate()
        If resultbutton = 0 Then resultbutton = 2
    End Sub
    
    Private Sub TabStripObjetos_Click()
        If Not TabStripObjetos.SelectedItem Is Nothing Then
            FichaIndex = TabStripObjetos.SelectedItem.index
            With interface
                Select Case FichaIndex
                    Case 1: .fillLvwEspec lvw, 6
                    Case 2: .fillLvwBrigadas lvw, 2
                    Case 3: .fillLvwAsig lvw, 5
                    Case 4: .fillLvwProfe lvw, 1
                    Case 5: .fillLvwLugar lvw, 3
                    Case 6: .fillLvwPeriodo lvw, 4
                    Case 7: .fillLvwRecurso lvw, 7
                End Select
            End With
        End If
    End Sub

'<!- METODOS -!>
    
    Public Sub refresca()
        Dim i As Long, turno As Long, dia As Long
    
        For i = 1 To MAX_DIAS * MAX_TURNOS
            turno = Int(((i - 1) / MAX_DIAS) + 1)
            dia = Int(i - (turno - 1) * MAX_DIAS)
            If BotonesRestriccion(dia, turno) = False Then
                cmdRes(i - 1).Picture = cmdEmpty.Picture
            Else
                If modo <> 6 Then cmdRes(i - 1).Picture = cmdRestricc.Picture
                If modo = 6 Then cmdRes(i - 1).Picture = cmdZpriori.Picture
            End If
    
            If Inhabil(dia, turno) Then
                cmdRes(i - 1).Enabled = False
                cmdRes(i - 1).BackColor = RGB(100 + Int(Rnd * 155), 100 + Int(Rnd * 155), 100 + Int(Rnd * 155))
                cmdRes(i - 1).Picture = cmdEmpty.Picture
            End If
    
        Next
    End Sub

